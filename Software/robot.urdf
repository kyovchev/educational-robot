<?xml version="1.0" encoding="utf-8"?>
<!--
  6-DOF Robot URDF — roboticstoolbox compatible
  =============================================
  Kinematic chain (SE3 ⊕ Rz convention):
    SE3(0,0,0.065)
    ⊕ Rz(q0) ⊕ SE3(0, 0.041, 0.042; roll=-90°)
    ⊕ Rz(q1) ⊕ SE3(0,-0.098, 0.001; roll=180°)
    ⊕ Rz(q2) ⊕ SE3(0, 0.041, 0.042; roll=-90°)
    ⊕ Rz(q3) ⊕ SE3(0, 0.041, 0.057; roll=-90°)
    ⊕ Rz(q4) ⊕ SE3(0,-0.041, 0.042; roll=+90°)
    ⊕ Rz(q5) ⊕ SE3(0, 0,     0.08;  yaw=180°)

  Joint axes in world frame at q=0 (verified numerically):
    J0 → +Z   J1 → +Y   J2 → -Y   J3 → +Z   J4 → +Y   J5 → +Z

  In URDF <axis> is expressed in the CHILD link frame.
  Since each joint frame IS the child link frame, all axes are <axis xyz="0 0 1">.

  Cylinder rpy values align the URDF cylinder Z-axis with each link's direction:
    link0 → col  : (0, 0, 0.065)         rpy (0,       0, 0)
    link1 → arm  : (0, 0.041, 0.042)     rpy (-0.7728, 0, 0)  = -44.31°
    link2 → arm  : (0,-0.098, 0.001)     rpy (+1.5600, 0, 0)  = +89.42°
    link3 → arm  : (0, 0.041, 0.042)     rpy (-0.7728, 0, 0)
    link4 → arm  : (0, 0.041, 0.057)     rpy (-0.6234, 0, 0)  = -35.73°
    link5 → arm  : (0,-0.041, 0.042)     rpy (+0.7728, 0, 0)  = +44.31°
    link6 → col  : (0, 0,     0.08)      rpy (0,       0, 0)
-->
<robot name="robot">

  <!-- ═══════════════════════════════════════════════════════════
       MATERIALS
  ═══════════════════════════════════════════════════════════ -->
  <material name="teal">   <color rgba="0.11 0.73 0.63 1.0"/> </material>
  <material name="coral">  <color rgba="0.91 0.35 0.24 1.0"/> </material>
  <material name="joint_disk"> <color rgba="0.15 0.15 0.15 1.0"/> </material>
  <material name="base_plate"> <color rgba="0.55 0.55 0.55 1.0"/> </material>
  <material name="ee_ball">    <color rgba="0.85 0.85 0.85 1.0"/> </material>

  <!-- ═══════════════════════════════════════════════════════════
       LINKS
  ═══════════════════════════════════════════════════════════ -->

  <!-- World / mounting frame -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 -0.004" rpy="0 0 0"/>
      <geometry><cylinder radius="0.025" length="0.008"/></geometry>
      <material name="base_plate"/>
    </visual>
  </link>

  <!--
    link0 — base column
    Carries the visual from (0,0,0) up to (0,0,0.065).
    Joint0 sits at the top of this column.
    Color: TEAL (even index 0)
  -->
  <link name="link0">
    <inertial>
      <mass value="0.10"/>
      <origin xyz="0 0 0.0325" rpy="0 0 0"/>
      <inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="5e-5"/>
    </inertial>
    <!-- Column cylinder -->
    <visual>
      <origin xyz="0 0 0.0325" rpy="0 0 0"/>
      <geometry><cylinder radius="0.012" length="0.065"/></geometry>
      <material name="teal"/>
    </visual>
    <!-- Joint0 disk (top of column) -->
    <visual>
      <origin xyz="0 0 0.065" rpy="0 0 0"/>
      <geometry><cylinder radius="0.018" length="0.010"/></geometry>
      <material name="joint_disk"/>
    </visual>
  </link>

  <!--
    link1 — first arm segment
    Direction: (0, 0.041, 0.042), length=0.0587 m
    Cylinder rpy = (-0.7728, 0, 0) aligns Z with direction.
    Joint1 disk at tip (0, 0.041, 0.042) — axis is Y in world → disk normal is Y.
    Color: CORAL (odd index 1)
  -->
  <link name="link1">
    <inertial>
      <mass value="0.10"/>
      <origin xyz="0 0.0205 0.0210" rpy="0 0 0"/>
      <inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="5e-5"/>
    </inertial>
    <!-- Arm cylinder -->
    <visual>
      <origin xyz="0 0.0205 0.0210" rpy="-0.77277 0 0"/>
      <geometry><cylinder radius="0.010" length="0.0587"/></geometry>
      <material name="coral"/>
    </visual>
    <!-- Joint1 disk — world axis is Y so disk lies in XZ plane, rpy=(π/2,0,0) -->
    <visual>
      <origin xyz="0 0.041 0.042" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.016" length="0.010"/></geometry>
      <material name="joint_disk"/>
    </visual>
  </link>

  <!--
    link2 — second arm segment
    Direction: (0, -0.098, 0.001), length=0.0980 m
    Cylinder rpy = (+1.5600, 0, 0) aligns Z with direction.
    Joint2 disk at tip — world axis is -Y → disk normal is Y, rpy=(π/2,0,0).
    Color: TEAL (even index 2)
  -->
  <link name="link2">
    <inertial>
      <mass value="0.10"/>
      <origin xyz="0 -0.0490 0.0005" rpy="0 0 0"/>
      <inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="5e-5"/>
    </inertial>
    <visual>
      <origin xyz="0 -0.0490 0.0005" rpy="1.5600 0 0"/>
      <geometry><cylinder radius="0.010" length="0.0980"/></geometry>
      <material name="teal"/>
    </visual>
    <visual>
      <origin xyz="0 -0.098 0.001" rpy="0 0 0"/>
      <geometry><cylinder radius="0.016" length="0.010"/></geometry>
      <material name="joint_disk"/>
    </visual>
  </link>

  <!--
    link3 — third arm segment
    Direction: (0, 0.041, 0.042), length=0.0587 m
    Cylinder rpy = (-0.7728, 0, 0).
    Joint3 disk at tip — world axis is Z → disk lies in XY plane, rpy=(0,0,0).
    Color: CORAL (odd index 3)
  -->
  <link name="link3">
    <inertial>
      <mass value="0.10"/>
      <origin xyz="0 0.0205 0.0210" rpy="0 0 0"/>
      <inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="5e-5"/>
    </inertial>
    <visual>
      <origin xyz="0 0.0205 0.0210" rpy="-0.77277 0 0"/>
      <geometry><cylinder radius="0.010" length="0.0587"/></geometry>
      <material name="coral"/>
    </visual>
    <visual>
      <origin xyz="0 0.041 0.042" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.016" length="0.010"/></geometry>
      <material name="joint_disk"/>
    </visual>
  </link>

  <!--
    link4 — fourth arm segment
    Direction: (0, 0.041, 0.057), length=0.0702 m
    Cylinder rpy = (-0.6234, 0, 0).
    Joint4 disk at tip — world axis is Y → rpy=(π/2,0,0).
    Color: TEAL (even index 4)
  -->
  <link name="link4">
    <inertial>
      <mass value="0.10"/>
      <origin xyz="0 0.0205 0.0285" rpy="0 0 0"/>
      <inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="5e-5"/>
    </inertial>
    <visual>
      <origin xyz="0 0.0205 0.0285" rpy="-0.62345 0 0"/>
      <geometry><cylinder radius="0.010" length="0.0702"/></geometry>
      <material name="teal"/>
    </visual>
    <visual>
      <origin xyz="0 0.041 0.057" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.016" length="0.010"/></geometry>
      <material name="joint_disk"/>
    </visual>
  </link>

  <!--
    link5 — fifth arm segment
    Direction: (0, -0.041, 0.042), length=0.0587 m
    Cylinder rpy = (+0.7728, 0, 0).
    Joint5 disk at tip — world axis is Z → rpy=(0,0,0).
    Color: CORAL (odd index 5)
  -->
  <link name="link5">
    <inertial>
      <mass value="0.10"/>
      <origin xyz="0 -0.0205 0.0210" rpy="0 0 0"/>
      <inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="5e-5"/>
    </inertial>
    <visual>
      <origin xyz="0 -0.0205 0.0210" rpy="0.77277 0 0"/>
      <geometry><cylinder radius="0.010" length="0.0587"/></geometry>
      <material name="coral"/>
    </visual>
    <visual>
      <origin xyz="0 -0.041 0.042" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.016" length="0.010"/></geometry>
      <material name="joint_disk"/>
    </visual>
  </link>

  <!--
    link6 — wrist / EE column
    Direction: (0, 0, 0.08), length=0.080 m — pure Z, no rotation needed.
    Color: TEAL (even index 6)
  -->
  <link name="link6">
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0.040" rpy="0 0 0"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.040" rpy="0 0 0"/>
      <geometry><cylinder radius="0.009" length="0.080"/></geometry>
      <material name="teal"/>
    </visual>
  </link>

  <!-- End-effector frame (tool0) -->
  <link name="tool0">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.008"/></geometry>
      <material name="ee_ball"/>
    </visual>
  </link>

  <!-- ═══════════════════════════════════════════════════════════
       JOINTS
  ═══════════════════════════════════════════════════════════ -->

  <!--
    base_link → link0  [FIXED]
    No transform: the base column visual handles the 65 mm rise internally.
    Joint0 origin below already adds the 65 mm offset.
  -->
  <joint name="base_to_link0" type="fixed">
    <parent link="base_link"/>
    <child  link="link0"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!--
    joint0 (q0): Rz in local frame
    Placed at top of base column: xyz=(0,0,0.065)
    No rotation in origin → local Z = world Z
    World rotation axis at q=0: +Z  ✓
  -->
  <joint name="joint0" type="revolute">
    <parent link="link0"/>
    <child  link="link1"/>
    <origin xyz="0 0 0.065" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.268928" upper="2.268928" effort="10.0" velocity="3.14159265"/>
    <dynamics damping="0.01" friction="0.0"/>
  </joint>

  <!--
    joint1 (q1): Rz in local frame
    Origin = SE3(0, 0.041, 0.042; roll=-90°)
    roll=-90° → local Y becomes world -Z, local Z becomes world +Y
    World rotation axis at q=0: +Y  ✓
  -->
  <joint name="joint1" type="revolute">
    <parent link="link1"/>
    <child  link="link2"/>
    <origin xyz="0 0.041 0.042" rpy="-1.57079632 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.268928" upper="2.268928" effort="10.0" velocity="3.14159265"/>
    <dynamics damping="0.01" friction="0.0"/>
  </joint>

  <!--
    joint2 (q2): Rz in local frame
    Origin = SE3(0, -0.098, 0.001; roll=180°)
    roll=180° flips Y and Z → local Z becomes world -Y
    World rotation axis at q=0: -Y  ✓
  -->
  <joint name="joint2" type="revolute">
    <parent link="link2"/>
    <child  link="link3"/>
    <origin xyz="0 -0.098 0.001" rpy="3.14159265 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.268928" upper="2.268928" effort="10.0" velocity="3.14159265"/>
    <dynamics damping="0.01" friction="0.0"/>
  </joint>

  <!--
    joint3 (q3): Rz in local frame
    Origin = SE3(0, 0.041, 0.042; roll=-90°)
    Accumulated: (-90°)+(180°)+(-90°) = -180°+180° → identity on Z
    World rotation axis at q=0: +Z  ✓
  -->
  <joint name="joint3" type="revolute">
    <parent link="link3"/>
    <child  link="link4"/>
    <origin xyz="0 0.041 0.042" rpy="-1.57079632 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.268928" upper="2.268928" effort="10.0" velocity="3.14159265"/>
    <dynamics damping="0.01" friction="0.0"/>
  </joint>

  <!--
    joint4 (q4): Rz in local frame
    Origin = SE3(0, 0.041, 0.057; roll=-90°)
    Accumulated roll: -90°+180°-90°-90° = -90° → local Z = world +Y
    World rotation axis at q=0: +Y  ✓
  -->
  <joint name="joint4" type="revolute">
    <parent link="link4"/>
    <child  link="link5"/>
    <origin xyz="0 0.041 0.057" rpy="-1.57079632 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.268928" upper="2.268928" effort="10.0" velocity="3.14159265"/>
    <dynamics damping="0.01" friction="0.0"/>
  </joint>

  <!--
    joint5 (q5): Rz in local frame
    Origin = SE3(0, -0.041, 0.042; roll=+90°)
    Accumulated roll: -90°+180°-90°-90°+90° = 0° → local Z = world +Z
    World rotation axis at q=0: +Z  ✓
  -->
  <joint name="joint5" type="revolute">
    <parent link="link5"/>
    <child  link="link6"/>
    <origin xyz="0 -0.041 0.042" rpy="1.57079632 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="10.0" velocity="3.14159265"/>
    <dynamics damping="0.01" friction="0.0"/>
  </joint>

  <!--
    joint6_ee [FIXED]: link6 → tool0
    Final SE3(0, 0, 0.08; yaw=180°)
    Pure Z translation + 180° yaw flipping the EE X/Y axes.
  -->
  <joint name="joint6_ee" type="fixed">
    <parent link="link6"/>
    <child  link="tool0"/>
    <origin xyz="0 0 0.08" rpy="0 0 3.14159265"/>
  </joint>

</robot>
